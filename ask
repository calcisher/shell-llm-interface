#!/usr/bin/env bash

# if error exit the program
set -e

if ! command -v curl >/dev/null 2>&1; then
  echo "Error: curl is required"
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq is required"
  exit 1
fi

# environment variables are checked
if [ -z "$ASK_API_URL" ]; then
  echo "Error: ASK_API_URL is not set"
  exit 1
fi

if [ -z "$ASK_MODEL" ]; then
  echo "Error: ASK_MODEL is not set"
  exit 1
fi

if [ -z "$ASK_API_KEY" ]; then
  echo "Error: ASK_API_KEY is not set"
  exit 1
fi

# if there is a piped input read it
if [ -p /dev/stdin ]; then
  PIPED_INPUT=$(cat)
else
  PIPED_INPUT=""
fi

ARGS="$*"

if [ -n "$PIPED_INPUT" ] && [ -n "$ARGS" ]; then
  USER_PROMPT="$ARGS"$'\n'"$PIPED_INPUT"
elif [ -n "$PIPED_INPUT" ]; then
  USER_PROMPT="$PIPED_INPUT"
else
  USER_PROMPT="$ARGS"
fi

if [ -z "$USER_PROMPT" ]; then
  echo "Error: No input provided"
  exit 1
fi

JSON_PAYLOAD=$(jq -n \
  --arg model "$ASK_MODEL" \
  --arg system "You are a CLI tool. Output plain text only. No yapping. Keep the output concise." \
  --arg user "$USER_PROMPT" \
  '{
    model: $model,
    messages: [
      { role: "system", content: $system },
      { role: "user", content: $user }
    ]
  }'
)

# request sent to api
RESPONSE=$(curl -s "$ASK_API_URL" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $ASK_API_KEY" \
  -d "$JSON_PAYLOAD"
)

echo "$RESPONSE" | jq -r '.choices[0].message.content'
